# Copy this file to .env and replace every placeholder before running seed or auth flows.

# Seeded Super Admin credentials.
# Used by the Super Admin seed flow to create exactly one owner account.
SEED_SUPER_ADMIN_EMAIL="super-admin@example.com"
SEED_SUPER_ADMIN_PASSWORD="replace-with-a-long-random-initial-password"

# Dashboard authentication secrets.
# AUTH_PASSWORD_PEPPER is mixed into password hashing and must be kept secret.
# JWT_SECRET signs/verifies auth-related JWTs when token helpers are used.
AUTH_PASSWORD_PEPPER="replace-with-a-long-random-password-pepper"
JWT_SECRET="replace-with-a-long-random-jwt-secret"

# Optional PayMongo API keys for future no-ads subscription flows.
PAYMONGO_SECRET_KEY="sk_test_1234567890abcdef"
PAYMONGO_PUBLIC_KEY="pk_test_1234567890abcdef"

